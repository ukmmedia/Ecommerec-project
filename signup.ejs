<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Sign Up · Loam & Co</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/user/store.css">
</head>
<body>
  <%- include('_header', { user: null, cartCount: 0 }) %>

  <div class="auth-wrap">
    <div class="auth-card">
      <h1>Create your account</h1>
      <p class="sub">Join to save your orders and check out faster.</p>

      <% if (error && error.length) { %><div class="msg error"><%= error[0] %></div><% } %>

      <form method="POST" action="/signup">
        <div class="form-row">
          <label>Full Name</label>
          <input type="text" name="name" required autofocus placeholder="Your name">
        </div>
        <div class="form-row">
          <label>Email</label>
          <input type="email" name="email" required placeholder="you@example.com">
        </div>
        <div class="form-row">
          <label>Password</label>
          <input type="password" name="password" required minlength="6" placeholder="At least 6 characters">
        </div>
        <div class="form-row">
          <label>Confirm Password</label>
          <input type="password" name="confirmPassword" required minlength="6" placeholder="Re-enter password">
        </div>
        <button type="submit" class="btn btn-block">Sign up</button>
      </form>

      <div class="auth-switch">Already have an account? <a href="/login">Log in</a></div>
    </div>
  </div>
</body>
</html>
