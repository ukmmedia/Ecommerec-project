<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Loam & Co · Everyday goods, made well</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/user/store.css">
</head>
<body>
  <%- include('_header', { user, cartCount: (typeof cartCount !== 'undefined' ? cartCount : 0) }) %>

  <section class="hero">
    <h1>Everyday goods, made to last.</h1>
    <p>Small-batch essentials for the home and pocket — thoughtfully made, honestly priced.</p>
  </section>

  <div class="categories">
    <span class="cat-pill">All</span>
    <% categories.forEach(c => { %><span class="cat-pill"><%= c %></span><% }) %>
  </div>

  <% if (products.length === 0) { %>
    <div class="empty-block">No products available right now. Check back soon.</div>
  <% } else { %>
  <div class="product-grid">
    <% products.forEach(p => { %>
      <a href="/product/<%= p.id %>" class="product-card" style="text-decoration:none;">
        <img class="product-img" src="<%= p.image %>" alt="<%= p.name %>" onerror="this.style.display='none'">
        <div class="product-body">
          <div class="product-cat"><%= p.category %></div>
          <div class="product-name"><%= p.name %></div>
          <div class="product-price">Rs <%= p.price.toLocaleString() %></div>
        </div>
      </a>
    <% }) %>
  </div>
  <% } %>

  <footer class="site-footer">© 2026 Loam & Co. All rights reserved.</footer>
</body>
</html>
