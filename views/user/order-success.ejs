<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Order Confirmed · Loam & Co</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/user/store.css">
</head>
<body>
  <%- include('_header', { user, cartCount: 0 }) %>

  <div class="success-wrap">
    <div class="success-icon">✓</div>
    <h1 style="font-size:24px; margin-bottom:8px;">Order Confirmed</h1>
    <p style="color:var(--ink-dim); margin-bottom:24px;">
      Order #<%= orderId %> placed successfully for Rs <%= total.toLocaleString() %>. We'll notify you once it ships.
    </p>
    <a href="/my-orders" class="btn">View My Orders</a>
    <a href="/" class="btn btn-outline" style="margin-left:10px;">Continue Shopping</a>
  </div>
</body>
</html>
