<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Checkout · Loam & Co</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/user/store.css">
</head>
<body>
  <%- include('_header', { user, cartCount: cart.reduce((s,i)=>s+i.qty,0) }) %>

  <div class="cart-wrap">
    <h1 class="display" style="font-size:26px; margin-bottom:24px;">Checkout</h1>

    <% cart.forEach(item => { %>
      <div class="cart-item">
        <img src="<%= item.image %>" onerror="this.style.display='none'">
        <div>
          <div class="cart-item-name"><%= item.name %></div>
          <div class="cart-item-meta">Qty: <%= item.qty %></div>
        </div>
        <div class="cart-item-price">Rs <%= (item.price * item.qty).toLocaleString() %></div>
      </div>
    <% }) %>

    <div class="cart-summary" style="margin-bottom:28px;">
      <span>Total</span>
      <span>Rs <%= total.toLocaleString() %></span>
    </div>

    <form method="POST" action="/checkout">
      <div class="form-row">
        <label>Delivery Address</label>
        <textarea name="address" required placeholder="House #, Street, City"></textarea>
      </div>
      <div class="form-row">
        <label>Phone Number</label>
        <input type="tel" name="phone" required placeholder="03XX-XXXXXXX">
      </div>
      <button type="submit" class="btn btn-sand btn-block" style="padding:14px;">Place Order</button>
    </form>
  </div>
</body>
</html>
