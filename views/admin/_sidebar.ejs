<aside class="sidebar">
  <div class="brand">
    <div class="brand-mark">A</div>
    <div class="brand-name">ADMIN CONSOLE</div>
  </div>
  <nav>
    <a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">
      <span class="ic">◧</span> Dashboard
    </a>
    <a href="/admin/products" class="<%= active === 'products' ? 'active' : '' %>">
      <span class="ic">◫</span> Products
    </a>
    <a href="/admin/orders" class="<%= active === 'orders' ? 'active' : '' %>">
      <span class="ic">◱</span> Orders
    </a>
    <a href="/admin/users" class="<%= active === 'users' ? 'active' : '' %>">
      <span class="ic">◍</span> Users
    </a>
  </nav>
  <div class="sidebar-footer">
    <div class="admin-chip">
      <div class="avatar"><%= admin.name.charAt(0) %></div>
      <div>
        <div class="admin-name"><%= admin.name %></div>
        <div class="admin-email"><%= admin.email %></div>
      </div>
    </div>
    <form method="POST" action="/admin/logout">
      <button type="submit" class="logout-btn">Log out</button>
    </form>
  </div>
</aside>
