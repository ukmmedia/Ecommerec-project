<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Users · Admin Console</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/admin/admin.css">
</head>
<body>
<div class="app-shell">
  <%- include('_sidebar', { active: 'users' }) %>

  <main class="main">
    <div class="page-header">
      <div>
        <h1>Users</h1>
        <p class="sub">Everyone registered on your storefront.</p>
      </div>
    </div>

    <div class="panel">
      <% if (users.length === 0) { %>
        <div class="empty-state">No registered users yet.</div>
      <% } else { %>
        <table>
          <thead><tr><th>Name</th><th>Email</th><th>Joined</th><th></th></tr></thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td><%= u.name %></td>
                <td><%= u.email %></td>
                <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                <td style="text-align:right;">
                  <form method="POST" action="/admin/users/<%= u.id %>/delete" onsubmit="return confirm('Remove this user?')">
                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
