<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>My Orders · Loam & Co</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/user/store.css">
</head>
<body>
  <%- include('_header', { user, cartCount: 0 }) %>

  <div class="cart-wrap">
    <h1 class="display" style="font-size:26px; margin-bottom:24px;">My Orders</h1>

    <% if (orders.length === 0) { %>
      <div class="empty-block">
        <p>You haven't placed any orders yet.</p>
        <a href="/" class="btn" style="margin-top:12px;">Start Shopping</a>
      </div>
    <% } else { %>
      <% orders.forEach(order => { %>
        <div class="cart-item" style="align-items:flex-start;">
          <div style="flex:1;">
            <div class="cart-item-name">Order #<%= order.id %> — <%= order.status %></div>
            <div class="cart-item-meta"><%= new Date(order.createdAt).toLocaleDateString() %></div>
            <div class="cart-item-meta" style="margin-top:6px;">
              <%= order.items.map(i => `${i.name} ×${i.qty}`).join(', ') %>
            </div>
          </div>
          <div class="cart-item-price">Rs <%= order.total.toLocaleString() %></div>
        </div>
      <% }) %>
    <% } %>
  </div>
</body>
</html>
